    "## 写一个绘制peaks的文件\n",
    "reps = ['rep1', 'rep2']\n",
    "tags = ['H3K27ac', 'H3K4me3']\n",
    "samples = ['anthers','cotyledon', 'ovules', 'fiber_5DPA', 'fiber_10DPA', 'fiber_20DPA', 'hypocotyl', 'leaf', 'petals', 'radicle', 'root', 'stem', 'stigma']\n",
    "colors = ['#FFE3DE', '#ED877C', '#FFA77E', '#FFDC85', '#A2BF74', '#5F9595', '#F0BC68', '#F5D1C3', '#C4D7D1', '#FFB6A3', '#EB9331', '#FDC76F', '#8ED1E2']\n",
    "fp = open('chip_peaks.ini', 'w')\n",
    "for k in range(13):\n",
    "    for j in tags:\n",
    "        for i in reps:\n",
    "            line0 = \"[{0}_{1}_{2}]\".format(samples[k], j, i)\n",
    "            line1 = 'file = ../peaks/{0}/{0}_{1}_{2}_bdgcmp_noscaff.bw'.format(samples[k], j, i)\n",
    "            line2 = 'color = {0}'.format(colors[k])\n",
    "            line3 = 'title = {0}_{1}_{2}'.format(samples[k], j, i)\n",
    "            line4 = 'height = 3'\n",
    "            line5 = '[spacer]'\n",
    "            line6 = 'height = 0.05'\n",
    "            print(line0, file=fp)\n",
    "            print(line1, file=fp)\n",
    "            print(line2, file=fp)\n",
    "            print(line3, file=fp)\n",
    "            print(line4, file=fp)\n",
    "            print(line5, file=fp)\n",
    "            print(line6, file=fp)\n",
    "fp.close()"
   ]
  },
