    "## 分析同源基因loop的调控关系\n",
    "df_h3k4me3 = pd.read_csv(\"F:/TM-1_leaf_3D-genome/HiC/loop/loop_3k/gene/all_region-gene_H3K4me3.txt\", sep=\"\\t\", names=['c', 's', 'e', 'geneid', 'one', 'two', 'three', 'four'])\n",
    "df_h3k27ac = pd.read_csv(\"F:/TM-1_leaf_3D-genome/HiC/loop/loop_3k/gene/all_region-gene_H3K27ac.txt\", sep=\"\\t\", names=['c', 's', 'e', 'geneid', 'one', 'two', 'three', 'four'])\n",
    "df_h3K27me3 = pd.read_csv(\"F:/TM-1_leaf_3D-genome/HiC/loop/loop_3k/gene/all_region-gene_H3K27me3.txt\", sep=\"\\t\", names=['c', 's', 'e', 'geneid', 'one', 'two', 'three', 'four'])\n",
    "df_enhancer = pd.read_csv(\"F:/TM-1_leaf_3D-genome/HiC/loop/loop_3k/gene/all_region-gene_enhancer.txt\", sep=\"\\t\", names=['c', 's', 'e', 'geneid', 'one', 'two', 'three', 'four'])\n",
    "\n",
    "\n",
    "\n",
    "df_h3k4me3 = df_h3k4me3[['c', 's', 'e', 'geneid']].copy()\n",
    "df_h3k27ac = df_h3k27ac[['c', 's', 'e', 'geneid']].copy()\n",
    "df_h3k27me3 = df_h3K27me3[['c', 's', 'e', 'geneid']].copy()\n",
    "df_enhancer = df_enhancer[['c', 's', 'e', 'geneid']].copy()\n",
    "\n",
    "df_h3k4me3['k4me3'] = [1]*df_h3k4me3.shape[0]\n",
    "df_h3k27ac['k27ac'] = [1]*df_h3k27ac.shape[0]\n",
    "df_h3k27me3['k27me3'] = [1]*df_h3k27me3.shape[0]\n",
    "df_enhancer['enhancer'] = [1]*df_enhancer.shape[0]\n",
    "\n",
    "df_one = pd.merge(df_h3k4me3, df_h3k27ac, how='outer', on=['c', 's', 'e', 'geneid'])\n",
    "df_two = pd.merge(df_one, df_h3k27me3, how='outer', on=['c', 's', 'e', 'geneid'])\n",
    "df_three = pd.merge(df_two, df_enhancer, how='outer', on=['c', 's', 'e', 'geneid'])\n",
    "df_tmp = df_three[['geneid', 'k4me3', 'k27ac', 'k27me3', 'enhancer']].copy()\n",
    "df_tmp.fillna(0, inplace=True)\n",
    "df_tmp1 = df_tmp.groupby('geneid', as_index=False)[['k4me3', 'k27ac', 'k27me3', 'enhancer']].sum()\n",
    "df_tmp1_at = df_tmp1.query(\"geneid.str.contains('Ghir_A')\", engine='python')\n",
    "df_tmp1_dt = df_tmp1.query(\"geneid.str.contains('Ghir_D')\", engine='python')\n",
    "df_tmp1_at.columns = ['geneid_at', 'k4me3_at', 'k27ac_at', 'k27me3_at', 'enhancer_at']\n",
    "df_tmp1_dt.columns = ['geneid_dt', 'k4me3_dt', 'k27ac_dt', 'k27me3_dt', 'enhancer_dt']\n",
    "df_hg = pd.read_csv('F:/TM-1_leaf_3D-genome/RNA_Seq/all_homo_gene_pairs_position.txt', sep='\\t')\n",
    "df_hg_id = df_hg[['geneid_at', 'geneid_dt']]\n",
    "df_one_result = pd.merge(df_hg_id, df_tmp1_at, how='outer', on=['geneid_at'])\n",
    "df_two_result = pd.merge(df_one_result, df_tmp1_dt, how='outer', on=['geneid_dt'])\n",
    "df_result = df_two_result.dropna(subset=['geneid_at', 'geneid_dt'])\n",
    "df_result.fillna(0, inplace=True)\n",
    "df_result.to_csv('F:/TM-1_leaf_3D-genome/HiC/loop/chip_atac/all_homo_gene_tags.txt', sep='\\t', index=False)\n"
   ]
  },
